local _gunCache  = {}
local _origStats = {}

local function _scanGuns()
    for _, v in pairs(getgc(true)) do
        if type(v) == "table"
        and rawget(v, "ModuleName")
        and rawget(v, "FireRate")
        and not _origStats[v] then
            _origStats[v] = {
                LimitedAmmoEnabled     = rawget(v,"LimitedAmmoEnabled"),
                AmmoCost               = rawget(v,"AmmoCost"),
                Ammo                   = rawget(v,"Ammo"),
                MaxAmmo                = rawget(v,"MaxAmmo"),
                ReloadTime             = rawget(v,"ReloadTime"),
                Recoil                 = rawget(v,"Recoil"),
                Spread                 = rawget(v,"Spread"),
                CameraRecoilingEnabled = rawget(v,"CameraRecoilingEnabled"),
                Auto                   = rawget(v,"Auto"),
                FireRate               = rawget(v,"FireRate"),
                ShotgunEnabled         = rawget(v,"ShotgunEnabled"),
                BulletPerShot          = rawget(v,"BulletPerShot"),
                ShotgunPattern         = rawget(v,"ShotgunPattern"),
            }
            table.insert(_gunCache, v)
        end
    end
end

local function _updateGuns()
    for _, v in ipairs(_gunCache) do
        _pcall(function()
            if setreadonly then setreadonly(v, false) end
            local o = _origStats[v]
            v.LimitedAmmoEnabled     = C.InfAmmo  and false         or o.LimitedAmmoEnabled
            v.AmmoCost               = C.InfAmmo  and 0             or o.AmmoCost
            v.Ammo                   = C.InfAmmo  and 999999        or o.Ammo
            v.MaxAmmo                = C.InfAmmo  and 999999        or o.MaxAmmo
            v.ReloadTime             = C.InfAmmo  and 0             or o.ReloadTime
            v.Recoil                 = C.NoRecoil and 0             or o.Recoil
            v.Spread                 = C.NoRecoil and 0             or o.Spread
            v.CameraRecoilingEnabled = C.NoRecoil and false         or o.CameraRecoilingEnabled
            v.Auto                   = C.FastFire and true          or o.Auto
            v.FireRate               = C.FastFire and C.FireRate    or o.FireRate
            v.ShotgunEnabled         = C.Multishot and true         or o.ShotgunEnabled
            v.BulletPerShot          = C.Multishot and C.BulletPerShot or o.BulletPerShot
            v.ShotgunPattern         = C.Multishot and false        or o.ShotgunPattern
            if setreadonly then setreadonly(v, true) end
        end)
    end
end

