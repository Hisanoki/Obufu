local function _isFriend(pl)
    if not C.FriendCheck then return false end
    local id = pl.UserId
    if _friendCache[id] ~= nil then return _friendCache[id] end
    local ok, r = _pcall(function() return LocalPlayer:IsFriendsWith(id) end)
    _friendCache[id] = ok and r or false
    return _friendCache[id]
end

task.spawn(function()
    while task.wait(0.1) do
        _pcall(function()
            if not C.SilentAim and not C.MagicBullets then
                _currentTarget = nil; return
            end
            local ch = LocalPlayer.Character
            _holdingGun = ch and ch:FindFirstChildOfClass("Tool") ~= nil
            if not _holdingGun then _currentTarget = nil; return end
            local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
            local best, shortest = nil, C.FOV
            for _, pl in ipairs(Players:GetPlayers()) do
                if pl == LocalPlayer or not pl.Character then continue end
                if C.TeamCheck and pl.Team and LocalPlayer.Team and pl.Team == LocalPlayer.Team then continue end
                if _isFriend(pl) then continue end
                local part = pl.Character:FindFirstChild(C.AimPart)
                local hum  = pl.Character:FindFirstChildOfClass("Humanoid")
                if not part or not hum or hum.Health <= 0 then continue end
                local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
                if not onScreen then continue end
                local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
                if d < shortest then shortest = d; best = part end
            end
            _currentTarget = best
        end)
    end
end)

local _oldNC
_oldNC = hookmetamethod(game, "__namecall", function(self, ...)
    if not C.SilentAim and not C.MagicBullets then return _oldNC(self, ...) end
    local m = getnamecallmethod()
    if not checkcaller() and _currentTarget and _holdingGun and self == workspace then
        local args = {...}
        if m == "Raycast" then
            local orig, dir = args[1], args[2]
            if typeof(orig)=="Vector3" and typeof(dir)=="Vector3" and dir.Magnitude > 5 then
                local tPos = _currentTarget.Position
                if C.MagicBullets then
                    local u = (tPos - Camera.CFrame.Position).Unit
                    args[1] = tPos - (u * 1.5); args[2] = u * 100
                else
                    args[2] = (tPos - orig).Unit * dir.Magnitude
                end
                return _oldNC(self, unpack(args))
            end
        elseif m == "FindPartOnRayWithIgnoreList" or m == "FindPartOnRay" then
            local ray = args[1]
            if typeof(ray)=="Ray" and ray.Direction.Magnitude > 5 then
                local tPos = _currentTarget.Position
                if C.MagicBullets then
                    local u = (tPos - Camera.CFrame.Position).Unit
                    args[1] = Ray.new(tPos - (u*1.5), u*100)
                else
                    args[1] = Ray.new(ray.Origin, (tPos - ray.Origin).Unit * ray.Direction.Magnitude)
                end
                return _oldNC(self, unpack(args))
            end
        end
    end
    return _oldNC(self, ...)
end)

local function _updateESP()
    if not C.ESPEnabled then return end
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl == LocalPlayer then continue end
        _pcall(function()
            local ch  = pl.Character; if not ch then return end
            local hum = ch:FindFirstChildOfClass("Humanoid"); if not hum then return end
            local head= ch:FindFirstChild("Head"); if not head then return end
            if hum.Health <= 0 then
                local e=head:FindFirstChild("StarCrowESP"); if e then e:Destroy() end
                local c=ch:FindFirstChild("StarCrowChams"); if c then c:Destroy() end
                return
            end
            local esp = head:FindFirstChild("StarCrowESP")
            if not esp then
                esp = Instance.new("BillboardGui"); esp.Name="StarCrowESP"
                esp.Adornee=head; esp.Size=UDim2.new(0,350,0,24)
                esp.StudsOffset=Vector3.new(0,1.2,0)
                esp.AlwaysOnTop=true; esp.MaxDistance=math.huge
                local lbl=Instance.new("TextLabel",esp); lbl.Name="L"
                lbl.Size=UDim2.new(1,0,1,0); lbl.BackgroundTransparency=1
                lbl.RichText=true; lbl.Font=Enum.Font.GothamBold; lbl.TextSize=12
                lbl.TextStrokeTransparency=0; lbl.TextStrokeColor3=Color3.new(0,0,0)
                lbl.TextColor3=Color3.fromRGB(255,255,255)
                esp.Parent=head
            end
            local lbl=esp:FindFirstChild("L"); if not lbl then return end
            local dist=math.floor((Camera.CFrame.Position-head.Position).Magnitude)
            local hp  =math.floor((hum.Health/math.max(hum.MaxHealth,1))*100)
            local tR,tG,tB=255,255,255
            local teamCol=Color3.fromRGB(255,255,255)
            if pl.Team then
                teamCol=pl.Team.TeamColor.Color
                tR=math.floor(teamCol.R*255); tG=math.floor(teamCol.G*255); tB=math.floor(teamCol.B*255)
            end
            local hc=hp>70 and "rgb(0,255,127)" or hp>30 and "rgb(255,200,0)" or "rgb(255,50,50)"
            lbl.Text=string.format(
                '<font color="rgb(%d,%d,%d)">%s</font> | %dm | <font color="%s">%d%%</font>',
                tR,tG,tB,pl.DisplayName,dist,hc,hp)
            local chams=ch:FindFirstChild("StarCrowChams")
            if not chams then
                chams=Instance.new("Highlight"); chams.Name="StarCrowChams"; chams.Parent=ch
            end
            chams.FillColor=teamCol; chams.OutlineColor=teamCol
            chams.FillTransparency=0.7; chams.OutlineTransparency=0
            chams.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
        end)
    end
end

