    Content = "• Auto Collect Item Mansion\n• Auto Collect Animals\n• Auto Collect Chest\n• Auto Collect Bag\n• Auto Sell"
})

local AutoCollectEnabled = false
Tabs.Westbound:AddToggle("AutoCollect", {
    Title = "Auto Collect & Auto Sell", Default = false,
    Callback = function(v)
        AutoCollectEnabled = v
        if not v then return end

        -- Collect Bags
        task.spawn(function()
            local inv = ReplicatedStorage:WaitForChild("GeneralEvents",9e9):WaitForChild("Inventory",9e9)
            while AutoCollectEnabled do
                local items = workspace:FindFirstChild("Items")
                if items then
                    local bags = items:FindFirstChild("InventoryBags")
                    if bags then
                        for _, bag in ipairs(bags:GetChildren()) do
                            task.spawn(function() pcall(function() inv:InvokeServer("GiveBag", bag) end) end)
                        end
                    end
                end
                task.wait()
            end
        end)

        -- Pickup Items
        task.spawn(function()
            local pickup = ReplicatedStorage:WaitForChild("GeneralEvents",9e9):WaitForChild("PickUpItem",9e9)
            while AutoCollectEnabled do
                local char = LocalPlayer.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                local items = workspace:FindFirstChild("Items")
                if root and items then
                    local myPos = root.Position
                    local sub = items:FindFirstChild("Items")
                    if sub then
                        for _, item in ipairs(sub:GetChildren()) do
                            local part = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart",true)
                            if part and (myPos-part.Position).Magnitude <= 20 then
                                pcall(function() pickup:FireServer(item) end)
                            end
                        end
                    end
                end
                task.wait(0.2)
            end
        end)

        -- Skin Animals
        task.spawn(function()
            local skinEvent = ReplicatedStorage:WaitForChild("GeneralEvents",9e9):WaitForChild("SkinAnimal",9e9)
            while AutoCollectEnabled do
                local char = LocalPlayer.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                local animals = workspace:FindFirstChild("Animals")
                if root and animals then
                    local myPos = root.Position
                    for _, animal in ipairs(animals:GetChildren()) do
                        local part = animal:FindFirstChild("HumanoidRootPart")
                                  or animal:FindFirstChildWhichIsA("BasePart",true)
                        if part and (myPos-part.Position).Magnitude <= 25 then
                            pcall(function() skinEvent:FireServer(animal) end)
                        end
                    end
                end
                task.wait(0.2)
            end
        end)

        -- Auto Sell
        task.spawn(function()
            local inv = ReplicatedStorage:WaitForChild("GeneralEvents",9e9):WaitForChild("Inventory",9e9)
            while AutoCollectEnabled do
                pcall(function() inv:InvokeServer("Sell") end)
                task.wait(1.5)
            end
        end)
    end
})
