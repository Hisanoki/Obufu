Tabs.Westbound:AddParagraph({ Title = "Misc", Content = "" })

local AutoBreakLassoEnabled = false
Tabs.Westbound:AddToggle("AutoBreakLasso", {
    Title = "Auto Break Lasso", Default = false,
    Callback = function(v)
        AutoBreakLassoEnabled = v
        if v then
            task.spawn(function()
                local lassoEvent = ReplicatedStorage:WaitForChild("GeneralEvents",9e9):WaitForChild("LassoEvents",9e9)
                while AutoBreakLassoEnabled do
                    local isTied = false
                    local char = LocalPlayer.Character
                    local hum  = char and char:FindFirstChildOfClass("Humanoid")
                    if char and hum then
                        if hum.PlatformStand then isTied = true end
                        if not isTied then
                            for _, child in ipairs(char:GetDescendants()) do
                                if child:IsA("RopeConstraint")
                                or (child:IsA("Weld") and child.Name:lower():match("lasso")) then
                                    isTied = true; break
                                end
                            end
                        end
                    end
                    if isTied then
                        pcall(function() lassoEvent:FireServer("BreakFree") end)
                        task.wait(0.1)
                    else
                        task.wait(0.5)
                    end
                end
            end)
        end
    end
})

Tabs.Westbound:AddParagraph({ Title = "Auto Collect & Sell", Content = "" })
