Tabs.Westbound:AddParagraph({ Title = "Gun Mods", Content = "" })

Tabs.Westbound:AddButton({
    Title = "Fast Reload + Fast Fire",
    Callback = function()
        local function patchReload(stat)
            if setreadonly then setreadonly(stat, false) end
            stat.FullReload = true
            stat.ReloadSpeed = 0.01
            stat.ReloadAnimationSpeed = 10
            if setreadonly then setreadonly(stat, true) end
        end
        local function patchFire(stat)
            if setreadonly then setreadonly(stat, false) end
            stat.prepTime = 0.01; stat.equipTime = 0.01
            if stat.FanFirePrepTime ~= nil then stat.FanFirePrepTime = 0.01 end
            if setreadonly then setreadonly(stat, true) end
        end
        pcall(function()
            local GS = require(ReplicatedStorage:WaitForChild("GunScripts"):WaitForChild("GunStats"))
            if GS.FanFirePrepTime ~= nil then
                if setreadonly then setreadonly(GS, false) end
                GS.FanFirePrepTime = 0.01
                if setreadonly then setreadonly(GS, true) end
            end
            for _, stat in pairs(GS) do
                if type(stat)=="table" and stat.GunType=="Pistol" then
                    pcall(function() patchReload(stat); patchFire(stat) end)
                end
            end
        end)
        for _, v in pairs(getgc(true)) do
            if type(v)=="table" and rawget(v,"GunType")=="Pistol" then
                pcall(function() patchReload(v); patchFire(v) end)
            end
        end
        Fluent:Notify({ Title = "Fast Fire ON", Content = "Applies to ALL Pistols. Shoot slowly to avoid ghost damage!", Duration = 6 })
    end
})

Tabs.Westbound:AddParagraph({ Title = "Rob & Interactions", Content = "" })

local AuraRobEnabled = false
Tabs.Westbound:AddToggle("AuraRob", {
    Title = "Aura Rob", Default = false,
    Callback = function(v)
        AuraRobEnabled = v
        if v then
            task.spawn(function()
                local robRemote = ReplicatedStorage:WaitForChild("GeneralEvents",9e9):WaitForChild("Rob",9e9)
                while AuraRobEnabled do
                    local char = LocalPlayer.Character
                    if char and char:FindFirstChild("HumanoidRootPart") then
                        local myPos = char.HumanoidRootPart.Position
                        for _, obj in ipairs(workspace:GetDescendants()) do
                            if obj.Name=="Safe" or obj.Name=="Cash" or obj.Name=="Gold"
                            or obj.Name=="Loot" or string.match(obj.Name,"Register") then
                                local part = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart",true)
                                if part and (myPos-part.Position).Magnitude <= 25 then
                                    pcall(function()
                                        if obj.Name=="Safe" then
                                            local r = obj:FindFirstChild("OpenSafe")
                                            if r and r:IsA("RemoteEvent") then r:FireServer("Complete") end
                                        end
                                        local rt = string.match(obj.Name,"Register") and "Register" or "Safe"
                                        robRemote:FireServer(rt, obj)
                                    end)
                                end
                            end
                        end
                    end
                    task.wait(0.2)
                end
            end)
        end
    end
})

