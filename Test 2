-- ── [N] ESP UPDATE ────────────────────────────────
local function _updateESP()
    if not C.ESPEnabled then return end
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl == LocalPlayer then continue end
        _pcall(function()
            local ch  = pl.Character; if not ch then return end
            local hum = ch:FindFirstChildOfClass("Humanoid"); if not hum then return end
            local head = ch:FindFirstChild("Head"); if not head then return end
            if hum.Health <= 0 then
                local e = head:FindFirstChild("StarCrowESP"); if e then e:Destroy() end
                local c = ch:FindFirstChild("StarCrowChams"); if c then c:Destroy() end
                return
            end
            local esp = head:FindFirstChild("StarCrowESP")
            if not esp then
                esp = Instance.new("BillboardGui"); esp.Name = "StarCrowESP"
                esp.Adornee = head; esp.Size = UDim2.new(0,350,0,24)
                esp.StudsOffset = Vector3.new(0,1.4,0)
                esp.AlwaysOnTop = true; esp.MaxDistance = math.huge
                local lbl = Instance.new("TextLabel", esp)
                lbl.Name = "L"; lbl.Size = UDim2.new(1,0,1,0)
                lbl.BackgroundTransparency = 1; lbl.RichText = true
                lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 12
                lbl.TextStrokeTransparency = 0
                lbl.TextStrokeColor3 = Color3.new(0,0,0)
                lbl.TextColor3 = Color3.fromRGB(255,255,255)
                esp.Parent = head
            end
            local lbl = esp:FindFirstChild("L"); if not lbl then return end
            local dist = math.floor((Camera.CFrame.Position - head.Position).Magnitude)
            local hp   = math.floor((hum.Health / math.max(hum.MaxHealth,1)) * 100)
            local tR,tG,tB = 255,255,255
            local teamCol = Color3.fromRGB(255,255,255)
            if pl.Team then
                teamCol = pl.Team.TeamColor.Color
                tR = math.floor(teamCol.R*255)
                tG = math.floor(teamCol.G*255)
                tB = math.floor(teamCol.B*255)
            end
            local hpCol = hp>70 and "rgb(0,255,127)" or hp>30 and "rgb(255,200,0)" or "rgb(255,50,50)"
            lbl.Text = string.format(
                '<font color="rgb(%d,%d,%d)">%s</font> | %dm | <font color="%s">%d%%</font>',
                tR,tG,tB, pl.DisplayName, dist, hpCol, hp
            )
            local chams = ch:FindFirstChild("StarCrowChams")
            if not chams then
                chams = Instance.new("Highlight"); chams.Name = "StarCrowChams"
                chams.Parent = ch
            end
            chams.FillColor = teamCol; chams.OutlineColor = teamCol
            chams.FillTransparency = 0.7; chams.OutlineTransparency = 0
            chams.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        end)
    end
end

