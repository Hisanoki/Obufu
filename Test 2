-- ── [P] NAMECALL HOOK (Silent Aim) ────────────────
local function _initHook()
    if _namecallHooked then return end
    _namecallHooked = true
    _oldNC = hookmetamethod(game, "__namecall", function(self, ...)
        local m = getnamecallmethod()
        if not checkcaller() and self == workspace and currentTarget
           and (not C.ClickToAim or C.IsTapping)
           and (C.NoToolCheck or isHoldingGun) then
            if m=="Raycast" or m=="FindPartOnRayWithIgnoreList" or m=="FindPartOnRay" then
                local args = {...}
                local tPos = currentTarget.Position
                if C.Prediction then
                    local vel = Vector3.zero
                    _pcall(function() vel = currentTarget.AssemblyLinearVelocity end)
                    tPos = tPos + vel * C.PredictionFactor
                end
                if m=="Raycast" and typeof(args[2])=="Vector3" and args[2].Magnitude > 30 then
                    args[2] = (tPos - args[1]).Unit * args[2].Magnitude
                    return _oldNC(self, unpack(args))
                elseif (m=="FindPartOnRayWithIgnoreList" or m=="FindPartOnRay")
                        and args[1] and args[1].Direction.Magnitude > 30 then
                    args[1] = Ray.new(args[1].Origin, (tPos - args[1].Origin).Unit * args[1].Direction.Magnitude)
                    return _oldNC(self, unpack(args))
                end
            end
        end
        return _oldNC(self, ...)
    end)
end
