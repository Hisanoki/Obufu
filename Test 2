    return tab:AddToggle(id, { Title = title, Default = default, Callback = cb })
end
local function _slider(tab, id, title, default, min, max, cb)
    return tab:AddSlider(id, {
        Title = title, Default = default,
        Min = min, Max = max, Rounding = 0, Callback = cb,
    })
end
local function _drop(tab, id, title, values, default, cb)
    return tab:AddDropdown(id, { Title = title, Values = values, Default = default, Callback = cb })
