local function ToggleFluentUI(visible)
    for _, g in ipairs(game:GetService("CoreGui"):GetChildren()) do
        if g:IsA("ScreenGui") then
            for _, desc in ipairs(g:GetDescendants()) do
                if desc:IsA("TextLabel") and desc.Text == "StarCrowHub" then
                    local p = desc.Parent
                    while p and p.Parent ~= g do p = p.Parent end
                    if p and p:IsA("Frame") then p.Visible = visible; return end
                    break
                end
            end
        end
    end
end
