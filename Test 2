local function AddToCache(obj)
    if obj:IsA("Model") then
        task.delay(1, function()
            if obj and obj.Parent
            and obj:FindFirstChildOfClass("Humanoid")
            and (obj:FindFirstChild("Head") or obj:FindFirstChild("HumanoidRootPart"))
            and not Players:GetPlayerFromCharacter(obj)
            and obj ~= LocalPlayer.Character then
                if not table.find(NPCCache, obj) then table.insert(NPCCache, obj) end
            end
        end)
    end
end
for _, obj in ipairs(workspace:GetDescendants()) do AddToCache(obj) end
