-- ── [B] UTILS (pcall-wrapped, obfuscation-safe) ───
local function _pcall(fn, ...)
    local ok, r = pcall(fn, ...)
    return ok, r
end

local function _get(parent, name, timeout)
    -- WaitForChild với fallback để không crash khi obfuscate
    timeout = timeout or 10
    local ok, r = _pcall(function()
        return parent:WaitForChild(name, timeout)
    end)
    return ok and r or parent:FindFirstChild(name)
end

local function _req()
    return request or (syn and syn.request) or (http and http.request)
        or http_request or (fluxus and fluxus.request)
end

