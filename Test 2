--  AIM TARGET LOOP
-- ──────────────────────────────────────────────
local function IsTargetVisible(targetPart, myChar)
    local origin = Camera.CFrame.Position
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {myChar, Camera}
    params.FilterType = Enum.RaycastFilterType.Exclude
    local result = workspace:Raycast(origin, targetPart.Position - origin, params)
    return not (result and result.Instance and not result.Instance:IsDescendantOf(targetPart.Parent))
end

local function isFriend(player)
    if not S.Config.FriendCheck then return false end
    local uid = player.UserId
    if FriendCache[uid] ~= nil then return FriendCache[uid] end
    local ok, res = pcall(function() return LocalPlayer:IsFriendsWith(uid) end)
    if ok then FriendCache[uid] = res; return res end
    return false
end

task.spawn(function()
    while task.wait(0.05) do
        local char = LocalPlayer.Character
        isHoldingGun = char and char:FindFirstChildOfClass("Tool") ~= nil
        if not (S.Config.AimPlayer or S.Config.AimNPC)
        or not char or not char:FindFirstChild("HumanoidRootPart")
        or not (S.Config.NoToolCheck or isHoldingGun) then
            currentTarget = nil; continue
        end
        local myPos  = char.HumanoidRootPart.Position
        local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        local best   = nil; local shortest = math.huge

        local function process(obj, isPlayer)
            local hum  = obj:FindFirstChildOfClass("Humanoid")
            local part = obj:FindFirstChild(S.Config.AimPart) or obj:FindFirstChild("Head")
            if not hum or hum.Health <= 0 or not part then return end
            if isPlayer then
                local plr = Players:GetPlayerFromCharacter(obj)
                if not plr or plr == LocalPlayer then return end
                if S.Config.TeamCheck and plr.Team == LocalPlayer.Team then return end
                if S.Config.FriendCheck and isFriend(plr) then return end
                if plr.Team and string.match(string.lower(plr.Team.Name), "civilian") then return end
            end
            if S.Config.WallCheck and not IsTargetVisible(part, char) then return end
            local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
            if not onScreen then return end
            if S.Config.AimMode == "FOV" then
                local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                if d < S.Config.FOVRadius and d < shortest then shortest=d; best=part end
            else
                local d3 = (part.Position - myPos).Magnitude
                if d3 < shortest then shortest=d3; best=part end
            end
        end

        if S.Config.AimPlayer then
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Character then process(p.Character, true) end
            end
        end
        if S.Config.AimNPC then
            for i = #NPCCache, 1, -1 do
                local npc = NPCCache[i]
                if npc and npc.Parent and not Players:GetPlayerFromCharacter(npc) then
                    process(npc, false)
                else table.remove(NPCCache, i) end
            end
        end
        currentTarget = best
    end
end)

-- ──────────────────────────────────────────────
--  SILENT AIM HOOK
-- ──────────────────────────────────────────────
function InitSilentAimHook()
    if isNamecallHooked then return end
    isNamecallHooked = true
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        if not (S.Config.AimPlayer or S.Config.AimNPC) then return oldNamecall(self, ...) end
        local method = getnamecallmethod()
        if not checkcaller() and self == workspace and currentTarget
        and (not S.Config.ClickToAim or S.Config.IsTapping)
        and (S.Config.NoToolCheck or isHoldingGun) then
            if method=="Raycast" or method=="FindPartOnRayWithIgnoreList" or method=="FindPartOnRay" then
                local args = {...}
                local tp   = currentTarget.Position
                if S.Config.Prediction then
                    local vel = currentTarget.AssemblyLinearVelocity
                    if vel then tp = tp + vel * S.Config.PredictionFactor end
                end
                if method=="Raycast" and typeof(args[2])=="Vector3" and args[2].Magnitude > 30 then
                    args[2] = (tp - args[1]).Unit * args[2].Magnitude
                    return oldNamecall(self, unpack(args))
                elseif (method=="FindPartOnRayWithIgnoreList" or method=="FindPartOnRay")
                and args[1] and args[1].Direction.Magnitude > 30 then
                    args[1] = Ray.new(args[1].Origin, (tp - args[1].Origin).Unit * args[1].Direction.Magnitude)
                    return oldNamecall(self, unpack(args))
                end
            end
        end
        return oldNamecall(self, ...)
    end)
end
getgenv()._SC_InitHook = InitSilentAimHook

