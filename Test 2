local function CreateFloatButton(name, text, defaultPos)
    local btn = Instance.new("TextButton")
    btn.Name = name; btn.Size = UDim2.new(0, 50, 0, 50); btn.Position = defaultPos
    btn.BackgroundColor3 = Color3.fromRGB(62, 62, 62); btn.BackgroundTransparency = 1
    btn.AutoButtonColor = false; btn.Text = text; btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold; btn.TextSize = 13; btn.Visible = false; btn.Parent = FloatGui
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0.25, 0)
    local stroke = Instance.new("UIStroke", btn)
    stroke.Thickness = 1.6; stroke.Color = Color3.fromRGB(255, 255, 255)
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    local grad = Instance.new("UIGradient", stroke)
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,   Color3.fromRGB(60, 0, 120)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 100, 200)),
        ColorSequenceKeypoint.new(1,   Color3.fromRGB(60, 0, 120)),
    })
    task.spawn(function()
        TweenService:Create(grad, TweenInfo.new(3, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {Rotation = 180}):Play()
    end)
    local dr, di, ds, sp = false, nil, nil, nil
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dr = true; di = input; ds = input.Position; sp = btn.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dr and input == di then
            local d = input.Position - ds
            btn.Position = UDim2.new(sp.X.Scale, sp.X.Offset+d.X, sp.Y.Scale, sp.Y.Offset+d.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input == di then dr = false; di = nil end
    end)
    return btn, grad
end

