--  ESP ANIMALS
-- ──────────────────────────────────────────────
local function updateAnimalESP()
    local animalsFolder = workspace:FindFirstChild("Animals")
    if not animalsFolder then return end
    for _, animal in ipairs(animalsFolder:GetChildren()) do
        local hum   = animal:FindFirstChildWhichIsA("Humanoid")
        local torso = animal:FindFirstChild("Torso") or animal:FindFirstChild("LowerTorso")
        if hum and torso then
            local esp = torso:FindFirstChild("AnimalESP")
            if ESPAnimalsEnabled and hum.Health > 0 then
                if not esp then
                    esp = Instance.new("BillboardGui")
                    esp.Name = "AnimalESP"; esp.Adornee = torso
                    esp.Size = UDim2.new(0, 350, 0, 30)
                    esp.StudsOffset = Vector3.new(0, 2, 0)
                    esp.AlwaysOnTop = true
                    local text = Instance.new("TextLabel")
                    text.Name = "NameText"; text.Parent = esp
                    text.Size = UDim2.new(1,0,1,0); text.BackgroundTransparency = 1
                    text.TextColor3 = Color3.new(1,1,1); text.TextSize = 12
                    text.Font = Enum.Font.GothamBold
                    text.TextStrokeTransparency = 0; text.RichText = true
                    esp.Parent = torso
                end
                local dist = math.floor((Camera.CFrame.Position - torso.Position).Magnitude)
                local hp   = math.floor((hum.Health / hum.MaxHealth) * 100)
                local cleanName = string.split(animal.Name, "{")[1] or animal.Name
                local nameColor = "rgb(200,200,200)"
                local lower = string.lower(cleanName)
                if string.match(lower,"legend") or string.match(lower,"direwolf") or string.match(lower,"dire wolf") then
                    nameColor = "rgb(255,215,0)"
                end
                local hpColor = hp>70 and "rgb(0,255,127)" or hp>30 and "rgb(255,200,0)" or "rgb(255,50,50)"
                esp.NameText.Text = string.format(
                    '<font color="%s">%s</font> | %dm | <font color="%s">%d%%</font>',
                    nameColor, cleanName, dist, hpColor, hp)
            else
                if esp then esp:Destroy() end
            end
        end
    end
end

