            local dist=math.floor((Camera.CFrame.Position-torso.Position).Magnitude)
            local hp=math.floor((hum.Health/math.max(hum.MaxHealth,1))*100)
            local rawName = animal.Name:split("{")[1] or animal.Name
            local nc = rawName:lower():match("legend") and "rgb(255,215,0)" or "rgb(200,200,200)"
            local hc = hp>70 and "rgb(0,255,127)" or hp>30 and "rgb(255,200,0)" or "rgb(255,50,50)"
            lbl.Text=string.format('<font color="%s">%s</font> | %dm | <font color="%s">%d%%</font>',
                nc,rawName,dist,hc,hp)
        end)
    end
end

-- ── [O] AIM LOOP ──────────────────────────────────
local function _canSee(part, myChar)
    if not C.WallCheck then return true end
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {myChar, Camera}
    rp.FilterType = Enum.RaycastFilterType.Exclude
    local res = workspace:Raycast(Camera.CFrame.Position, part.Position - Camera.CFrame.Position, rp)
    return not (res and res.Instance and not res.Instance:IsDescendantOf(part.Parent))
end

local function _isFriend(pl)
    if not C.FriendCheck then return false end
    local id = pl.UserId
    if FriendCache[id] ~= nil then return FriendCache[id] end
    local ok, r = _pcall(function() return LocalPlayer:IsFriendsWith(id) end)
    FriendCache[id] = ok and r or false
    return FriendCache[id]
end

local function _processChar(obj, isPlayer, myChar, center, shortest, bestTarget)
    local hum  = obj:FindFirstChildOfClass("Humanoid")
    local part = obj:FindFirstChild(C.AimPart) or obj:FindFirstChild("Head")
    if not hum or hum.Health <= 0 or not part then return shortest, bestTarget end

    if isPlayer then
        local pl = Players:GetPlayerFromCharacter(obj)
        if not pl or pl == LocalPlayer then return shortest, bestTarget end
        if C.TeamCheck and pl.Team and pl.Team == LocalPlayer.Team then return shortest, bestTarget end
        if _isFriend(pl) then return shortest, bestTarget end
        -- Bỏ qua Civilian (westbound đặc thù)
        if pl.Team and pl.Team.Name:lower():match("civilian") then return shortest, bestTarget end
    end

    if not _canSee(part, myChar) then return shortest, bestTarget end
    local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
    if not onScreen then return shortest, bestTarget end

    local dist
    if C.AimMode == "FOV" then
        dist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if dist >= C.FOVRadius then return shortest, bestTarget end
    else
        dist = (part.Position - myChar.HumanoidRootPart.Position).Magnitude
    end

    if dist < shortest then return dist, part end
    return shortest, bestTarget
end

