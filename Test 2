local _GIST_ID    = "92086d0c65244c07ccb9afbfd7743c57"
local _GIST_TOKEN = "GÁN_TOKEN_CỦA_BẠN_VÀO_ĐÂY"
local _GIST_FILE  = "bans.json"

local function _fetchBans()
    local fn = _req(); if not fn then return {} end
    local ok, res = _pcall(fn, {
        Url     = "https://api.github.com/gists/" .. _GIST_ID,
        Method  = "GET",
        Headers = { ["Accept"] = "application/vnd.github+json" },
    })
    if not ok or not res or res.StatusCode ~= 200 then return {} end
    local ok2, data = _pcall(HttpService.JSONDecode, HttpService, res.Body)
    if not ok2 then return {} end
    local file = data.files and data.files[_GIST_FILE]
    if not file then return {} end
    local ok3, list = _pcall(HttpService.JSONDecode, HttpService, file.content)
    return (ok3 and type(list) == "table") and list or {}
end

