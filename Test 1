    WallCheck        = false,
    AimMode          = "FOV",
    AimPart          = "Head",
    FOVRadius        = 90,
    ClickToAim       = false,
    IsTapping        = false,
    NoToolCheck      = false,
    Prediction       = false,
    PredictionFactor = 0.15,
    ESPEnabled       = false,
    NoFog            = false,
    FullBright       = false,
    LoopSpeedEnabled = false,
    WalkSpeed        = 30,
    InfJumpEnabled   = false,
    NoclipEnabled    = false,
    AntiFallDamage   = false,
}

