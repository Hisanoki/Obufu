-- ── [1] COOLDOWN (chống re-execute liên tục) ──
do
    local COOLDOWN = 10
    local now = tick()
    if getgenv()._SC_Loaded then
        warn("[StarCrow] Already loaded.")
        return
    end
    if getgenv()._SC_LastExe and (now - getgenv()._SC_LastExe) < COOLDOWN then
        warn("[StarCrow] Execute too fast.")
        return
    end
    getgenv()._SC_LastExe = now
    getgenv()._SC_Loaded  = true
end

-- ── [2] ANTI LOADSTRING SPY ───────────────────
--  Kỹ thuật: spy hook thường wrap loadstring bằng
--  một Lua closure, còn bản gốc là C closure.
--  Ta dùng nhiều lớp kiểm tra để tránh bypass đơn giản.
do
    local function _kick(reason)
        warn("[StarCrow] Security check failed: " .. reason)
        -- Huỷ flag để không leak bất cứ thứ gì
        getgenv()._SC_Loaded  = nil
        getgenv()._SC_LastExe = nil
        game:GetService("Players").LocalPlayer:Kick(
            "\n[StarCrow Hub] Security violation detected.\n" ..
            "Reason: " .. reason
        )
    end

    -- CHECK 1: loadstring phải là C closure (bản gốc engine)
    if not iscclosure(loadstring) then
        _kick("loadstring is not a C-closure (hooked?)")
        return
    end

    -- CHECK 2: debug.info trên loadstring phải trỏ về [C]
    do
        local ok, src = pcall(debug.info, loadstring, "s")
        if ok and src and src ~= "[C]" then
            _kick("loadstring source is not [C]: " .. tostring(src))
            return
        end
    end

    -- CHECK 3: Thử gọi một chuỗi "canary" vô hại.
    --  Nếu spy đang chạy, nó sẽ in/clipboard nội dung này.
    --  Còn ta dùng pcall để chắc chắn không crash.
    --  (Không thể phát hiện clipboard leak từ phía client,
    --   nhưng kết hợp check 1+2 đủ để chặn script thông thường.)
    do
        local _canary = "-- SC_CANARY_7f3a9b"
        local fn, err = loadstring(_canary)
        -- loadstring hợp lệ sẽ trả về nil, "attempt to..." vì
        -- _canary là comment, không có code thực thi → trả về function rỗng
        -- Quan trọng: nếu bị hook, check 1 đã chặn rồi
        -- Ở đây ta chỉ verify loadstring còn hoạt động bình thường
        if type(fn) ~= "function" then
            -- comment thuần túy vẫn compile thành function hợp lệ
            _kick("loadstring returned unexpected result for canary")
            return
        end
    end

    -- CHECK 4: So sánh upvalue count của loadstring gốc
    --  hookfunction thường thêm upvalue để giữ ref hàm cũ
    do
        local ok, n = pcall(debug.info, loadstring, "u")  -- số upvalue
        -- C closure = 0 upvalue; Lua wrapper sẽ có >= 1
        if ok and type(n) == "number" and n > 0 then
            _kick("loadstring has unexpected upvalues (" .. n .. ")")
            return
        end
    end
end

