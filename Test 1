    game:GetService("Players").LocalPlayer:Kick("Westbound only!")
    return
end

local Players     = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local HttpService = game:GetService("HttpService")

-- BAN LIST
local function FetchBanList()
    local ok, res = pcall(function()
        -- Nhớ thay URL thực tế của file JSON Ban List vào đây nhé
        return game:HttpGet("URL_BAN_JSON_CỦA_BẠN")
    end)
    if not ok then return {} end
    local ok2, list = pcall(HttpService.JSONDecode, HttpService, res)
    return (ok2 and type(list) == "table") and list or {}
end

local n, id = LocalPlayer.Name, tostring(LocalPlayer.UserId)
for _, e in ipairs(FetchBanList()) do
    local banned = (type(e)=="table" and (e.name==n or e.id==id))
               or  (type(e)=="string" and (e==n or e==id))
    if banned then
        LocalPlayer:Kick((type(e)=="table" and e.reason~="") 
            and "[StarCrowHub] Banned: "..e.reason 
            or  "[StarCrowHub] You are banned.")
        return
    end
end

