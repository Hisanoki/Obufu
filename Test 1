-- ================================================
-- HỆ THỐNG BAN LIST GỐC (TỪ GITHUB GISTS)
-- ================================================
local GIST_ID      = "92086d0c65244c07ccb9afbfd7743c57 "
local GIST_TOKEN   = "  "
local GIST_FILE    = "bans.json"

local function HttpRequest(options)
    local fn = request or syn and syn.request or http and http.request or nil
    if fn then return fn(options) end
    return nil
end

local function FetchBanList()
    local ok, res = pcall(HttpRequest, {
        Url     = "https://api.github.com/gists/" .. GIST_ID,
        Method  = "GET",
        Headers = { ["Accept"] = "application/vnd.github+json" }
    })
    if not ok or not res or res.StatusCode ~= 200 then return {} end
    local ok2, data = pcall(HttpService.JSONDecode, HttpService, res.Body)
    if not ok2 or not data then return {} end
    local file = data.files and data.files[GIST_FILE]
    if not file then return {} end
    local ok3, list = pcall(HttpService.JSONDecode, HttpService, file.content)
    return (ok3 and type(list) == "table") and list or {}
end

local BanList = FetchBanList()

do
    local n  = LocalPlayer.Name
    local id = tostring(LocalPlayer.UserId)
    for _, entry in ipairs(BanList) do
        local matchName = type(entry) == "table" and entry.name == n
        local matchId   = type(entry) == "table" and entry.id   == id
        local legacyStr = type(entry) == "string" and (entry == n or entry == id)
        if matchName or matchId or legacyStr then
            local reason = (type(entry) == "table" and entry.reason ~= "") and entry.reason or nil
            local msg = reason
                and "[StarCrowHub] You are banned. Reason: " .. reason
                or  "[StarCrowHub] You are banned from using this script."
            LocalPlayer:Kick(msg)
            return
        end
    end
end

