do
    local COOLDOWN = 10
    local now = tick()
    if getgenv()._SC_Loaded then
        warn("[StarCrow] Already loaded.")
        return
    end
    if getgenv()._SC_LastExe and (now - getgenv()._SC_LastExe) < COOLDOWN then
        warn("[StarCrow] Execute too fast.")
        return
    end
    getgenv()._SC_LastExe = now
    getgenv()._SC_Loaded  = true
end

do
    local function _kick(reason)
        warn("[StarCrow] Security check failed: " .. reason)
        getgenv()._SC_Loaded  = nil
        getgenv()._SC_LastExe = nil
        game:GetService("Players").LocalPlayer:Kick(
            "\n[StarCrow Hub] Security violation detected.\n" ..
            "Reason: " .. reason
        )
    end

    if not iscclosure(loadstring) then
        _kick("loadstring is not a C-closure (hooked?)")
        return
    end

    do
        local ok, src = pcall(debug.info, loadstring, "s")
        if ok and src and src ~= "[C]" then
            _kick("loadstring source is not [C]: " .. tostring(src))
            return
        end
    end

    do
        local _canary = "-- SC_CANARY_7f3a9b"
        local fn, err = loadstring(_canary)
        if type(fn) ~= "function" then
            _kick("loadstring returned unexpected result for canary")
            return
        end
    end

    do
        local ok, n = pcall(debug.info, loadstring, "u")
        if ok and type(n) == "number" and n > 0 then
            _kick("loadstring has unexpected upvalues (" .. n .. ")")
            return
        end
    end
end

if game.PlaceId ~= 2474168535 then
    game:GetService("Players").LocalPlayer:Kick(
        "[StarCrow] This script only supports Westbound!"
    )
    return
end

getgenv().StarConfig = {
